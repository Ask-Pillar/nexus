{
  "manifest_version": 3,
  "name": "Nexus Web Ingest",
  "version": "0.1",
  "description": "自动采集 AI 对话内容 → Nexus 记忆系统",
  "permissions": ["storage"],
  "host_permissions": [
    "https://*.douyin.com/*",
    "https://*.doubao.com/*",
    "https://tongyi.aliyun.com/*",
    "https://chat.openai.com/*",
    "https://chatgpt.com/*"
  ],
  "content_scripts": [{
    "matches": [
      "https://*.douyin.com/*",
      "https://*.doubao.com/*", 
      "https://tongyi.aliyun.com/*",
      "https://chat.openai.com/*",
      "https://chatgpt.com/*"
    ],
    "js": ["content.js"]
  }],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  }
}
